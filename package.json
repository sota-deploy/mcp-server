{
  "name": "@sota-io/mcp",
  "version": "1.2.0",
  "mcpName": "io.github.sota-deploy/sota",
  "description": "MCP server for sota.io — EU-native DevOps PaaS. Deploy web apps via AI agents with managed PostgreSQL, zero-downtime deploys, and automatic HTTPS. Supports Next.js, Node.js, Python, and custom Dockerfiles.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sota-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "CLAUDE.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sota-deploy/mcp-server.git"
  },
  "homepage": "https://sota.io/docs/mcp",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sota",
    "deploy",
    "paas",
    "ai-agent",
    "claude",
    "devops"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@sota-io/sdk": "^1.0.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
